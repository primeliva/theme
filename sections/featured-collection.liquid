<div class="sec">
  <div class="row-between">
    <div>
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="h2">{{ section.settings.heading }}</h2>
    </div>
    {%- if section.settings.collection != blank -%}
      <a href="{{ collections[section.settings.collection].url }}" style="font-weight:700;font-size:15px;color:var(--green);">View all products →</a>
    {%- endif -%}
  </div>
  <div class="grid-4">
    {%- assign coll = collections[section.settings.collection] -%}
    {%- if coll != blank and coll.products_count > 0 -%}
      {%- for product in coll.products limit: section.settings.count -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="card"><div class="card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder' }}</div><div class="card__body"><h3 class="card__title">Example product</h3><div class="card__price"><span class="now">₹2,499</span></div></div></div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New arrivals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This week's bestsellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "min": 2, "max": 8, "step": 1, "label": "Products to show", "default": 4 }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
