<header class="header">
  <div class="header__row">
    <a href="{{ routes.root_url }}" class="logo">
      <span class="logo__name">{{ shop.name | default: 'PrimeLiva' }}</span>
      <span class="logo__tag">{{ section.settings.tagline | default: 'Your Urban Marketplace' }}</span>
    </a>
    <nav class="nav">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a>
      {%- else -%}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        <a href="{{ routes.root_url }}pages/contact">Contact</a>
      {%- endfor -%}
    </nav>
    <div class="header__icons">
      <a href="{{ routes.search_url }}" aria-label="Search">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#19213B" stroke-width="1.7"/><path d="M16.5 16.5L21 21" stroke="#19213B" stroke-width="1.7" stroke-linecap="round"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" aria-label="Cart" style="position:relative;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 8h14l-1.2 10.2a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8Z" stroke="#19213B" stroke-width="1.6"/><path d="M9 8V6.5a3 3 0 0 1 6 0V8" stroke="#19213B" stroke-width="1.6"/></svg>
        <span class="cart-count" style="position:absolute;top:-7px;right:-8px;">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>
{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Your Urban Marketplace" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
