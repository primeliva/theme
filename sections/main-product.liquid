{%- liquid
  assign p = product
-%}
<div class="pdp">
  <div style="font-size:13px;color:#8A8578;font-weight:600;margin:24px 0 8px;">
    <a href="{{ routes.root_url }}">Home</a> / <a href="{{ routes.all_products_collection_url }}">Shop</a> / <span style="color:#19213B;">{{ p.title }}</span>
  </div>
  <div class="pdp__grid">
    <div class="pdp__media">
      <div class="pdp__main" id="pdpMain">
        {%- if p.compare_at_price > p.price -%}
          {%- assign pct = p.compare_at_price | minus: p.price | times: 100.0 | divided_by: p.compare_at_price | round -%}
          <span class="badge-save" style="top:16px;left:16px;border-radius:999px;padding:6px 12px;">Save {{ pct }}%</span>
        {%- endif -%}
        {%- if p.featured_media -%}
          <img id="pdpMainImg" src="{{ p.featured_media | image_url: width: 1000 }}" alt="{{ p.title | escape }}">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      {%- if p.media.size > 1 -%}
        <div class="pdp__thumbs">
          {%- for media in p.media -%}
            <div class="pdp__thumb"><img src="{{ media | image_url: width: 168 }}" alt="" onclick="document.getElementById('pdpMainImg').src='{{ media | image_url: width: 1000 }}'"></div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="pdp__info">
      {%- if p.type != blank -%}<span class="pdp__cat">{{ p.type }}</span>{%- endif -%}
      <h1>{{ p.title }}</h1>
      {%- if p.metafields.custom.subtitle != blank -%}<p class="pdp__sub">{{ p.metafields.custom.subtitle }}</p>{%- endif -%}

      <div class="pdp__rating"><span class="stars" style="font-size:16px;letter-spacing:2px;">★★★★★</span><span>{{ p.metafields.custom.rating | default: '4.8' }} · {{ p.metafields.custom.reviews | default: '1,200+' }} reviews</span></div>

      {%- assign chips = p.metafields.custom.chips.value | default: section.settings.chips -%}
      {%- if chips != blank -%}
        <div class="pdp__chips">
          {%- assign chiplist = chips | split: ',' -%}
          {%- for c in chiplist -%}
            <span class="chip"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>{{ c | strip }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="pdp__price">
        <span class="now">{{ p.price | money }}</span>
        {%- if p.compare_at_price > p.price -%}
          <span class="was">{{ p.compare_at_price | money }}</span>
          {%- assign pct = p.compare_at_price | minus: p.price | times: 100.0 | divided_by: p.compare_at_price | round -%}
          <span class="save">Save {{ pct }}%</span>
        {%- endif -%}
      </div>

      <div class="pdp__desc">{{ p.description }}</div>

      {%- assign benefits = p.metafields.custom.benefits.value | default: section.settings.benefits -%}
      {%- if benefits != blank -%}
        <div class="benefits">
          {%- assign blist = benefits | split: '|' -%}
          {%- for b in blist -%}
            <div class="benefit"><span class="ic"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>{{ b | strip }}</div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_prepaid -%}
        <div class="offer">⚡ Get an <strong>&nbsp;extra 5% off&nbsp;</strong> on prepaid orders — applied at checkout.</div>
      {%- endif -%}

      {% form 'product', p %}
        <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
        {%- unless p.has_only_default_variant -%}
          <div style="margin-bottom:14px;">
            {%- for option in p.options_with_values -%}
              <div style="font-size:12px;font-weight:700;letter-spacing:.06em;color:#8A8578;text-transform:uppercase;margin-bottom:8px;">{{ option.name }}</div>
              <select name="options[{{ option.name | escape }}]" class="field" style="margin-bottom:14px;">
                {%- for value in option.values -%}<option value="{{ value | escape }}">{{ value }}</option>{%- endfor -%}
              </select>
            {%- endfor -%}
          </div>
        {%- endunless -%}
        <div class="buybox">
          <div class="qty">
            <button type="button" onclick="var q=this.parentNode.querySelector('input');q.value=Math.max(1,(parseInt(q.value)||1)-1)">−</button>
            <input type="number" name="quantity" value="1" min="1">
            <button type="button" onclick="var q=this.parentNode.querySelector('input');q.value=(parseInt(q.value)||1)+1">+</button>
          </div>
          <button type="submit" name="add" class="btn btn-green atc">Add to Cart — {{ p.price | money }}</button>
        </div>
      {% endform %}

      <button class="btn btn-dark btn-block" onclick="window.location.href='{{ routes.cart_url }}'" style="margin-bottom:18px;">Buy It Now</button>

      <div class="trust-mini">
        <div><span class="d"></span>Free Pan-India shipping</div>
        <div><span class="d"></span>Cash on Delivery</div>
        <div><span class="d"></span>30-day money back</div>
        <div><span class="d"></span>6-month warranty</div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} ===== Marketing blocks (editable in theme editor) ===== {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- case block.type -%}

    {%- when 'feature_strip' -%}
      <div class="sec" {{ block.shopify_attributes }}>
        <div class="fstrip">
          {%- assign items = block.settings.items | newline_to_br | split: '<br />' -%}
          {%- for it in items -%}
            {%- assign parts = it | strip | split: '::' -%}
            {%- if parts[0] != blank -%}
              <div class="f"><div class="ic"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#146A53" stroke-width="1.7"/><path d="M8 12.3l2.6 2.6L16 9.4" stroke="#146A53" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg></div><h3>{{ parts[0] | strip }}</h3><p>{{ parts[1] | strip }}</p></div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- when 'stats' -%}
      <div class="sec" style="padding:20px 24px 8px;" {{ block.shopify_attributes }}>
        <div class="stats">
          <div class="stats__bar"></div>
          <div class="stats__eyebrow"><span class="l"></span><span class="t">{{ block.settings.eyebrow | default: 'By the numbers' }}</span><span class="l"></span></div>
          <div class="stats__grid">
            {%- assign rows = block.settings.items | newline_to_br | split: '<br />' -%}
            {%- for r in rows -%}
              {%- assign parts = r | strip | split: '::' -%}
              {%- if parts[0] != blank -%}
                <div class="stats__cell"><div class="v">{{ parts[0] | strip }}</div><div class="u"></div><div class="l2">{{ parts[1] | strip }}</div></div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'steps' -%}
      <div class="sec" {{ block.shopify_attributes }}>
        <div class="sec__head"><span class="eyebrow">{{ block.settings.eyebrow | default: 'Simple in 3 steps' }}</span><h2 class="h2">{{ block.settings.heading | default: 'How it works' }}</h2></div>
        <div class="tiles-3">
          {%- for i in (1..3) -%}
            {%- assign img = block.settings['image_' | append: i] -%}
            {%- assign ttl = block.settings['title_' | append: i] -%}
            {%- assign txt = block.settings['text_' | append: i] -%}
            {%- if ttl != blank -%}
              <div><div class="tile" style="position:relative;"><span class="step__num">{{ i }}</span><div class="tile__media">{%- if img -%}<img src="{{ img | image_url: width: 600 }}" alt="">{%- else -%}{{ 'image' | placeholder_svg_tag: 'placeholder' }}{%- endif -%}</div></div><h3 style="font-size:18px;font-weight:700;margin:16px 0 6px;">{{ ttl }}</h3><p style="font-size:14.5px;color:#5A6072;margin:0;line-height:1.55;">{{ txt }}</p></div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- when 'included' -%}
      <div class="sec" {{ block.shopify_attributes }}>
        <div class="sec__head"><span class="eyebrow">In the box</span><h2 class="h2">{{ block.settings.heading | default: "What's included" }}</h2></div>
        <div class="tiles-3">
          {%- assign rows = block.settings.items | newline_to_br | split: '<br />' -%}
          {%- for r in rows -%}
            {%- if r | strip != blank -%}
              <div style="text-align:center;"><div class="tile" style="margin-bottom:16px;"><div class="tile__media">{{ 'image' | placeholder_svg_tag: 'placeholder' }}</div></div><p style="font-size:15px;font-weight:600;margin:0;">{{ r | strip }}</p></div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- when 'faq' -%}
      <div class="faq" {{ block.shopify_attributes }}>
        <div class="sec">
          <div class="sec__head"><h2 class="h2">{{ block.settings.heading | default: 'Frequently asked questions' }}</h2></div>
          <div class="faq__list">
            {%- assign rows = block.settings.items | newline_to_br | split: '<br />' -%}
            {%- for r in rows -%}
              {%- assign parts = r | strip | split: '::' -%}
              {%- if parts[0] != blank -%}
                <details class="faq__item"><summary class="faq__q">{{ parts[0] | strip }}<span class="faq__sign">+</span></summary><p class="faq__a">{{ parts[1] | strip }}</p></details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'reviews' -%}
      <div class="sec" {{ block.shopify_attributes }}>
        <div class="sec__head"><h2 class="h2">Loved by customers</h2><p style="font-size:13.5px;color:#9A958A;font-weight:600;">Verified reviews · powered by Loox</p></div>
        <div id="looxReviews" data-product-id="{{ p.id }}"></div>
      </div>

    {%- when 'guarantee' -%}
      <div class="sec" {{ block.shopify_attributes }}>
        <div class="guarantee">
          <div class="guarantee__seal"><b>30</b><span>DAYS</span></div>
          <div style="flex:1 1 320px;"><h2 class="h2" style="font-size:28px;">{{ block.settings.heading | default: '30-Day Money Back Guarantee' }}</h2><p style="font-size:15.5px;line-height:1.6;color:#5A6072;margin:10px 0 0;">{{ block.settings.text }}</p></div>
        </div>
      </div>

  {%- endcase -%}
{%- endfor -%}

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "textarea", "id": "chips", "label": "Spec chips (comma-separated)", "info": "Fallback when product has no custom.chips metafield", "default": "Cordless, 3 Heat Levels, Whisper Quiet, Lightweight" },
    { "type": "textarea", "id": "benefits", "label": "Benefits (separate with | )", "info": "Fallback when product has no custom.benefits metafield", "default": "Reduces fatigue & swelling|3 levels of soothing heat|3 modes & 3 intensities|USB-C rechargeable, fully wireless" },
    { "type": "checkbox", "id": "show_prepaid", "label": "Show prepaid offer", "default": true }
  ],
  "blocks": [
    {
      "type": "feature_strip",
      "name": "Feature strip",
      "settings": [
        { "type": "textarea", "id": "items", "label": "Items (one per line: Title :: Text)", "default": "Air Compression :: Relaxes tired muscles.\nSoothing Heat :: 3 levels of warmth.\n3 Modes · 3 Levels :: Comfort for everyone.\nWireless & Portable :: USB-C rechargeable." }
      ]
    },
    {
      "type": "stats",
      "name": "Stats band",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "By the numbers" },
        { "type": "textarea", "id": "items", "label": "Stats (one per line: Value :: Label)", "default": "2–5 hrs :: Battery life\n3 :: Massage modes\n3 :: Heat levels\nUSB-C :: Fast charging" }
      ]
    },
    {
      "type": "steps",
      "name": "How it works",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Simple in 3 steps" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "How it works" },
        { "type": "image_picker", "id": "image_1", "label": "Step 1 image" },
        { "type": "text", "id": "title_1", "label": "Step 1 title", "default": "Wrap" },
        { "type": "text", "id": "text_1", "label": "Step 1 text", "default": "Wrap it comfortably and secure the strap." },
        { "type": "image_picker", "id": "image_2", "label": "Step 2 image" },
        { "type": "text", "id": "title_2", "label": "Step 2 title", "default": "Select" },
        { "type": "text", "id": "text_2", "label": "Step 2 text", "default": "Choose your mode, intensity and heat." },
        { "type": "image_picker", "id": "image_3", "label": "Step 3 image" },
        { "type": "text", "id": "title_3", "label": "Step 3 title", "default": "Relax" },
        { "type": "text", "id": "text_3", "label": "Step 3 text", "default": "Sit back and enjoy soothing relief." }
      ]
    },
    {
      "type": "included",
      "name": "What's included",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "What's included" },
        { "type": "textarea", "id": "items", "label": "Items (one per line)", "default": "1 × Leg Massager\n1 × Type-C Charging Cable\n1 × User Manual" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
        { "type": "textarea", "id": "items", "label": "Q&A (one per line: Question :: Answer)", "default": "How long does delivery take? :: Orders ship within 24 hours and arrive in 3–6 days, free.\nIs Cash on Delivery available? :: Yes, COD is available across India.\nWhat is your return policy? :: 30-day money-back guarantee on every order." }
      ]
    },
    { "type": "reviews", "name": "Reviews (Loox)", "settings": [] },
    {
      "type": "guarantee",
      "name": "Guarantee",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "30-Day Money Back Guarantee" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "We're confident you'll love it. If you're not completely satisfied, return it within 30 days for a full refund." }
      ]
    }
  ]
}
{% endschema %}
