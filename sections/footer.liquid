<footer class="footer">
  <div class="footer__top">
    <div class="footer__brand">
      <span class="logo__name">{{ shop.name | default: 'PrimeLiva' }}</span>
      <span class="logo__tag" style="display:block;margin-top:4px;">{{ section.settings.tagline | default: 'Your Urban Marketplace' }}</span>
      <p>{{ section.settings.blurb | default: 'Your urban marketplace for trending gadgets and home finds — loved by 10,000+ Indians.' }}</p>
      {% form 'customer', class: 'newsletter' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input class="field" type="email" name="contact[email]" placeholder="Join our email list" style="margin:0;background:#222B47;color:#fff;border-color:#353D58;">
        <button type="submit">Subscribe</button>
      {% endform %}
    </div>
    <div class="footer__cols">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading }}</h4>
          {%- for link in block.settings.menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="footer__pay">
    <div class="footer__pay-row">
      <div style="display:flex;align-items:center;gap:12px;">
        <span style="width:38px;height:38px;border-radius:11px;background:#1FA855;display:flex;align-items:center;justify-content:center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff"><path d="M12 2a10 10 0 00-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1012 2zm0 2a8 8 0 11-4.1 14.9l-.3-.2-2.8.8.8-2.7-.2-.3A8 8 0 0112 4z"/></svg>
        </span>
        <div>
          <div style="font-size:14px;font-weight:700;color:#fff;">Chat with us on WhatsApp — real humans, fast replies</div>
          <div style="font-size:13px;color:#8C92A4;">{{ section.settings.phone | default: '+91 98XXX XXXXX' }} · {{ section.settings.email | default: 'support@primeliva.com' }}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        <span class="pay-badge">VISA</span><span class="pay-badge">Mastercard</span><span class="pay-badge">UPI</span><span class="pay-badge">Paytm</span><span class="pay-badge">COD</span>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-row">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }} · {{ section.settings.tagline | default: 'Your Urban Marketplace' }}</span>
      <span>Free Shipping · COD · 30-Day Returns · 6-Month Warranty</span>
    </div>
  </div>
</footer>
{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Your Urban Marketplace" },
    { "type": "textarea", "id": "blurb", "label": "About blurb" },
    { "type": "text", "id": "email", "label": "Support email", "default": "support@primeliva.com" },
    { "type": "text", "id": "phone", "label": "Phone / WhatsApp", "default": "+91 98XXX XXXXX" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "menu", "settings": { "heading": "Shop" } },
      { "type": "menu", "settings": { "heading": "Help" } },
      { "type": "menu", "settings": { "heading": "Policies" } }
    ]
  }
}
{% endschema %}
