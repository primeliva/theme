<div class="trust">
  <div class="trust__grid">
    {%- for block in section.blocks -%}
      <div class="trust__item" {{ block.shopify_attributes }}>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#146A53" stroke-width="1.6"/><path d="M8 12.3l2.6 2.6L16 9.4" stroke="#146A53" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div><b>{{ block.settings.title }}</b><br><span>{{ block.settings.subtitle }}</span></div>
      </div>
    {%- endfor -%}
  </div>
</div>
{% schema %}
{
  "name": "Trust bar",
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Fast & Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Pan-India delivery" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "item", "settings": { "title": "Fast & Free Shipping", "subtitle": "Pan-India delivery" } },
      { "type": "item", "settings": { "title": "Cash on Delivery", "subtitle": "Pay when it arrives" } },
      { "type": "item", "settings": { "title": "Lowest Prices", "subtitle": "Best value, always" } },
      { "type": "item", "settings": { "title": "24/7 Support", "subtitle": "Always here to help" } }
    ]
  },
  "presets": [{ "name": "Trust bar" }]
}
{% endschema %}
