<div class="sec">
  <div class="sec__head"><h2 class="h2">{{ section.settings.heading | default: 'Shop by category' }}</h2></div>
  <div class="grid-4">
    {%- for block in section.blocks -%}
      {%- assign coll = collections[block.settings.collection] -%}
      <a href="{{ coll.url | default: '#' }}" class="cat-tile" {{ block.shopify_attributes }}>
        {%- if block.settings.image -%}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="">
        {%- elsif coll.featured_image -%}
          <img src="{{ coll.featured_image | image_url: width: 800 }}" alt="">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
        <span class="cat-tile__label">{{ block.settings.title | default: coll.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</div>
{% schema %}
{
  "name": "Categories",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "tile", "settings": { "title": "Wellness" } },
      { "type": "tile", "settings": { "title": "Kitchen" } },
      { "type": "tile", "settings": { "title": "Self-care" } },
      { "type": "tile", "settings": { "title": "Safety" } }
    ]
  },
  "presets": [{ "name": "Categories" }]
}
{% endschema %}
