<div class="sec">
  <h1 class="serif" style="font-weight:600;font-size:42px;letter-spacing:-.02em;margin:0 0 20px;">Search</h1>
  {% form 'search' %}
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products" class="field" style="max-width:480px;">
    <button type="submit" class="btn btn-green" style="margin-top:8px;">Search</button>
  {% endform %}
  {%- if search.performed -%}
    <div class="grid-3" style="margin-top:32px;">
      {%- for item in search.results -%}
        {%- if item.object_type == 'product' -%}{% render 'product-card', product: item %}{%- endif -%}
      {%- else -%}
        <p>No results found.</p>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
