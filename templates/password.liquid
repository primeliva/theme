<div class="sec" style="text-align:center;min-height:50vh;display:flex;flex-direction:column;align-items:center;justify-content:center;">
  <span class="logo__name" style="font-size:32px;">{{ shop.name }}</span>
  <h1 class="serif" style="font-weight:600;font-size:40px;letter-spacing:-.02em;margin:16px 0 8px;">Opening soon</h1>
  <p style="font-size:17px;color:#5A6072;margin:0 0 24px;">{{ shop.name }} is launching shortly.</p>
  {% form 'storefront_password' %}
    <input type="password" name="password" placeholder="Enter store password" class="field" style="max-width:300px;">
    <button type="submit" class="btn btn-green" style="margin-top:8px;">Enter</button>
  {% endform %}
</div>
