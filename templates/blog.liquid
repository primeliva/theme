<div class="sec">
  <h1 class="serif" style="font-weight:600;font-size:42px;letter-spacing:-.02em;margin:0 0 24px;">{{ blog.title }}</h1>
  <div class="grid-3">
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" class="card">
        <div class="card__media">{%- if article.image -%}<img src="{{ article.image | image_url: width: 600 }}" alt="">{%- else -%}{{ 'image' | placeholder_svg_tag: 'placeholder' }}{%- endif -%}</div>
        <div class="card__body"><h3 class="card__title">{{ article.title }}</h3><p style="font-size:14px;color:#5A6072;margin:0;">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p></div>
      </a>
    {%- endfor -%}
  </div>
</div>
