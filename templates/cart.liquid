<div class="sec">
  <h1 class="serif" style="font-weight:600;font-size:42px;letter-spacing:-.02em;margin:0 0 24px;">Your cart</h1>
  {%- if cart.item_count > 0 -%}
    {% form 'cart', cart %}
      <table style="width:100%;border-collapse:collapse;">
        <tbody>
        {%- for item in cart.items -%}
          <tr style="border-bottom:1px solid #ECE6DA;">
            <td style="padding:16px 0;width:90px;">{%- if item.image -%}<img src="{{ item.image | image_url: width: 160 }}" alt="" style="width:80px;height:80px;object-fit:cover;border-radius:12px;">{%- endif -%}</td>
            <td style="padding:16px;"><a href="{{ item.url }}" style="font-weight:700;">{{ item.product.title }}</a><div style="color:#5A6072;font-size:14px;">{{ item.variant.title | remove: 'Default Title' }}</div></td>
            <td style="padding:16px;"><input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="field" style="width:70px;margin:0;"></td>
            <td style="padding:16px;text-align:right;font-weight:700;">{{ item.final_line_price | money }}</td>
          </tr>
        {%- endfor -%}
        </tbody>
      </table>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:24px;flex-wrap:wrap;gap:16px;">
        <button type="submit" name="update" class="btn btn-outline">Update cart</button>
        <div style="text-align:right;">
          <div style="font-size:14px;color:#5A6072;">Subtotal</div>
          <div class="serif" style="font-size:28px;font-weight:600;">{{ cart.total_price | money }}</div>
        </div>
      </div>
      <button type="submit" name="checkout" class="btn btn-green btn-block" style="margin-top:20px;">Checkout</button>
    {% endform %}
  {%- else -%}
    <p style="font-size:17px;color:#5A6072;">Your cart is empty.</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn-green" style="margin-top:12px;">Continue shopping</a>
  {%- endif -%}
</div>
