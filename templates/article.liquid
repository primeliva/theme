<article class="sec" style="max-width:760px;">
  <h1 class="serif" style="font-weight:600;font-size:44px;letter-spacing:-.02em;margin:0 0 8px;">{{ article.title }}</h1>
  <div style="color:#8A8578;font-size:14px;margin-bottom:24px;">{{ article.published_at | date: '%B %d, %Y' }}</div>
  {%- if article.image -%}<img src="{{ article.image | image_url: width: 1200 }}" alt="" style="border-radius:20px;margin-bottom:24px;">{%- endif -%}
  <div style="font-size:16px;line-height:1.7;color:#3A3F38;">{{ article.content }}</div>
</article>
