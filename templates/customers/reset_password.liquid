<div class="sec" style="max-width:480px;">
  <h1 class="serif" style="font-weight:600;font-size:38px;letter-spacing:-.02em;margin:0 0 20px;">Reset password</h1>
  {% form 'recover_customer_password' %}
    {{ form.errors | default_errors }}
    {%- if form.posted_successfully? -%}<p style="color:var(--green);font-weight:600;">We've sent you a reset email.</p>{%- endif -%}
    <input class="field" type="email" name="email" placeholder="Email" required>
    <button type="submit" class="btn btn-green btn-block">Send reset link</button>
  {% endform %}
  <p style="margin-top:16px;font-size:14px;"><a href="{{ routes.account_login_url }}" style="color:var(--green);font-weight:600;">Back to login</a></p>
</div>
