<div class="sec" style="max-width:760px;">
  <a href="{{ routes.account_url }}" style="color:var(--green);font-weight:600;">← Back to account</a>
  <h1 class="serif" style="font-weight:600;font-size:38px;letter-spacing:-.02em;margin:14px 0 8px;">Order {{ order.name }}</h1>
  <div style="color:#8A8578;font-size:14px;margin-bottom:24px;">Placed {{ order.created_at | date: '%B %d, %Y' }}</div>
  <table style="width:100%;border-collapse:collapse;">
    <tbody>
      {%- for line in order.line_items -%}
        <tr style="border-top:1px solid #ECE6DA;"><td style="padding:12px 0;">{{ line.title }} × {{ line.quantity }}</td><td style="text-align:right;">{{ line.final_line_price | money }}</td></tr>
      {%- endfor -%}
    </tbody>
  </table>
  <div style="text-align:right;margin-top:16px;"><div style="font-size:14px;color:#5A6072;">Total</div><div class="serif" style="font-size:24px;font-weight:600;">{{ order.total_price | money }}</div></div>
</div>
