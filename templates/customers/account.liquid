<div class="sec" style="max-width:760px;">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:24px;">
    <h1 class="serif" style="font-weight:600;font-size:38px;letter-spacing:-.02em;margin:0;">My account</h1>
    <a href="{{ routes.account_logout_url }}" style="color:var(--green);font-weight:600;">Log out</a>
  </div>
  <p style="color:#5A6072;">Welcome back, {{ customer.first_name | default: customer.email }}.</p>
  <h2 class="serif" style="font-weight:600;font-size:24px;margin:24px 0 12px;">Order history</h2>
  {%- if customer.orders.size > 0 -%}
    <table style="width:100%;border-collapse:collapse;">
      <thead><tr style="text-align:left;color:#8A8578;font-size:13px;"><th style="padding:8px 0;">Order</th><th>Date</th><th>Total</th><th>Status</th></tr></thead>
      <tbody>
        {%- for order in customer.orders -%}
          <tr style="border-top:1px solid #ECE6DA;"><td style="padding:12px 0;"><a href="{{ order.customer_url }}" style="color:var(--green);font-weight:600;">{{ order.name }}</a></td><td>{{ order.created_at | date: '%b %d, %Y' }}</td><td>{{ order.total_price | money }}</td><td>{{ order.fulfillment_status_label }}</td></tr>
        {%- endfor -%}
      </tbody>
    </table>
  {%- else -%}
    <p style="color:#5A6072;">You haven't placed any orders yet.</p>
  {%- endif -%}
</div>
