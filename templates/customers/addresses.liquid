<div class="sec" style="max-width:560px;">
  <h1 class="serif" style="font-weight:600;font-size:38px;letter-spacing:-.02em;margin:0 0 20px;">Addresses</h1>
  {%- for address in customer.addresses -%}
    <div style="background:#fff;border:1px solid #ECE6DA;border-radius:16px;padding:20px;margin-bottom:14px;">
      <div style="font-size:15px;color:#3A3F38;line-height:1.5;">{{ address | format_address }}</div>
    </div>
  {%- else -%}
    <p style="color:#5A6072;">No saved addresses yet.</p>
  {%- endfor -%}
  <p style="margin-top:16px;"><a href="{{ routes.account_url }}" style="color:var(--green);font-weight:600;">← Back to account</a></p>
</div>
