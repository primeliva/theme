<div class="sec" style="max-width:480px;">
  <h1 class="serif" style="font-weight:600;font-size:38px;letter-spacing:-.02em;margin:0 0 20px;">Create account</h1>
  {% form 'create_customer' %}
    {{ form.errors | default_errors }}
    <input class="field" type="text" name="customer[first_name]" placeholder="First name">
    <input class="field" type="text" name="customer[last_name]" placeholder="Last name">
    <input class="field" type="email" name="customer[email]" placeholder="Email" required>
    <input class="field" type="password" name="customer[password]" placeholder="Password" required>
    <button type="submit" class="btn btn-green btn-block">Create</button>
  {% endform %}
  <p style="margin-top:16px;font-size:14px;color:#5A6072;">Already have an account? <a href="{{ routes.account_login_url }}" style="color:var(--green);font-weight:600;">Sign in</a></p>
</div>
